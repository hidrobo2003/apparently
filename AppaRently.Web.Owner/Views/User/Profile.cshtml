@model OwnerProfileViewModel

@{
    ViewData["Title"] = "Profile";
}

<section class="page-section">
    <div class="profile-grid">
        <div class="surface">
            <div class="surface__header">
                <h1 class="section-title">Profile</h1>
                <p class="section-subtitle mb-0">This information is visible only to the authenticated owner account.</p>
            </div>
            <div class="surface__body">
                <div class="kv-list">
                    <div class="kv-item">
                        <span class="kv-item__label">Full name</span>
                        <span class="kv-item__value">@Model.Owner.FullName</span>
                    </div>
                    <div class="kv-item">
                        <span class="kv-item__label">Email</span>
                        <span class="kv-item__value text-break-all">@Model.Owner.Email</span>
                    </div>
                    <div class="kv-item">
                        <span class="kv-item__label">Role</span>
                        <span class="kv-item__value">@Model.Owner.Role</span>
                    </div>
                    <div class="kv-item">
                        <span class="kv-item__label">Created</span>
                        <span class="kv-item__value">@Model.Owner.CreatedAt.ToString("yyyy-MM-dd HH:mm")</span>
                    </div>
                    <div class="kv-item">
                        <span class="kv-item__label">Updated</span>
                        <span class="kv-item__value">@Model.Owner.UpdatedAt?.ToString("yyyy-MM-dd HH:mm")</span>
                    </div>
                </div>

                <div class="toolbar mt-4">
                    <a asp-action="Edit" asp-route-id="@Model.Owner.Id" class="btn btn-primary">Update information</a>
                    <form asp-action="Destroy" asp-route-id="@Model.Owner.Id" method="post" class="d-inline">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-outline-dark">Delete account</button>
                    </form>
                </div>
            </div>
        </div>

        <div class="surface">
            <div class="surface__header">
                <h2 class="section-title">Reservation history</h2>
                <p class="section-subtitle mb-0">Most recent reservations appear first.</p>
            </div>
            <div class="surface__body p-0">
                @if (!Model.Reservations.Any())
                {
                    <div class="surface__body">
                        <p class="mb-0 muted">No reservations have been generated for your apartments yet.</p>
                    </div>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table align-middle mb-0">
                            <thead>
                                <tr>
                                    <th>Apartment</th>
                                    <th>Tenant</th>
                                    <th>Dates</th>
                                    <th>Price paid</th>
                                    <th>Created</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var reservation in Model.Reservations)
                                {
                                    <tr>
                                        <td>
                                            <div class="fw-semibold">@reservation.ApartmentTitle</div>
                                            <div class="muted text-break-all">@reservation.ApartmentAddress</div>
                                        </td>
                                        <td>
                                            <div class="fw-semibold">@reservation.TenantFullName</div>
                                            <div class="muted text-break-all">@reservation.TenantEmail</div>
                                        </td>
                                        <td>
                                            <div>@reservation.CheckIn.ToString("yyyy-MM-dd")</div>
                                            <div class="muted">@reservation.CheckOut.ToString("yyyy-MM-dd")</div>
                                        </td>
                                        <td>@reservation.PricePaid.ToString("C")</td>
                                        <td>@reservation.CreatedAt.ToString("yyyy-MM-dd HH:mm")</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>
    </div>
</section>
