@model ForgotPasswordViewModel

@{
    ViewData["Title"] = "Forgot password";
}

<section class="auth-page">
    <div class="auth-card">
        <div class="auth-card__body">
            <span class="eyebrow">Owner access</span>
            <h1 class="section-title mt-1">Forgot password</h1>
            <p class="section-subtitle mb-4">Enter your email to receive a reset link.</p>

            <form asp-action="ForgotPassword" method="post">
                @Html.AntiForgeryToken()
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <div class="mb-3">
                    <label asp-for="Email" class="form-label"></label>
                    <input asp-for="Email" class="form-control" autocomplete="email" />
                    <span asp-validation-for="Email" class="text-danger"></span>
                </div>

                <button type="submit" class="btn btn-primary w-100">Send reset link</button>
            </form>
        </div>
    </div>
</section>
