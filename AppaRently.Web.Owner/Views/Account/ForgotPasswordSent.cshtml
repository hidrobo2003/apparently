@{
    ViewData["Title"] = "Reset email sent";
}

<section class="auth-page">
    <div class="auth-card">
        <div class="auth-card__body">
            <span class="eyebrow">Owner access</span>
            <h1 class="section-title mt-1">Check your email</h1>
            <p class="section-subtitle mb-4">If the account exists, a reset link has been sent.</p>
            <a asp-action="Login" class="btn btn-primary w-100">Back to login</a>
        </div>
    </div>
</section>
