@inject IAppNotificationService NotificationService
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - AppaRently Owner</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/AppaRently.Web.Owner.styles.css" asp-append-version="true" />
</head>
<body>
    <header class="topbar">
        <div class="container-xl topbar__inner">
            <a class="brand" asp-controller="Home" asp-action="Index">AppaRently Owner</a>

            <nav class="topbar__nav">
                @{
                    var unreadNotifications = 0;
                    if (User.Identity?.IsAuthenticated == true && User.IsInRole(AppaRentlyRoles.Owner))
                    {
                        var userId = User.FindFirstValue(ClaimTypes.NameIdentifier);
                        if (!string.IsNullOrWhiteSpace(userId))
                        {
                            unreadNotifications = await NotificationService.CountUnreadAsync(userId);
                        }
                    }
                }
                @if (User.Identity?.IsAuthenticated == true && User.IsInRole(AppaRentlyRoles.Owner))
                {
                    <a class="topbar__link" asp-controller="Apartment" asp-action="Index">Dashboard</a>
                    <a class="topbar__link" asp-controller="Apartment" asp-action="Create">New apartment</a>
                    <a class="topbar__link" asp-controller="User" asp-action="Profile">Profile</a>
                    <a class="topbar__link" asp-controller="Notification" asp-action="Index">
                        Notifications
                        @if (unreadNotifications > 0)
                        {
                            <span class="badge rounded-pill bg-danger ms-1">@unreadNotifications</span>
                        }
                    </a>
                    <a class="topbar__link" asp-controller="Home" asp-action="Privacy">Privacy</a>
                    <form asp-controller="Account" asp-action="Logout" method="post" class="d-inline">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-outline-dark btn-sm">Sign out</button>
                    </form>
                }
                else
                {
                    <a class="topbar__link" asp-controller="Account" asp-action="Login">Login</a>
                    <a class="topbar__link" asp-controller="Account" asp-action="Register">Register</a>
                }
            </nav>
        </div>
    </header>

    <main class="page-shell">
        <div class="container-xl">
            @if (TempData["Message"] is string message && !string.IsNullOrWhiteSpace(message))
            {
                var success = bool.TryParse(TempData["Success"]?.ToString(), out var isSuccess) && isSuccess;
                <div class="alert @(success ? "alert-success" : "alert-danger") alert-dismissible fade show" role="alert">
                    @message
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            }

            @RenderBody()
        </div>
    </main>

    <footer class="app-footer">
        <div class="container-xl">
            <span>AppaRently Owner Portal</span>
            <a asp-controller="Home" asp-action="Privacy">Privacy</a>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
