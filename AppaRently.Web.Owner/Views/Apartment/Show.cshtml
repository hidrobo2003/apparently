@model ApartmentResponse

@{
    ViewData["Title"] = Model.Title;
    var imageUrl = string.IsNullOrWhiteSpace(Model.ImageUrl)
        ? "https://images.unsplash.com/photo-1560448204-603b3fc33ddc?auto=format&fit=crop&w=1600&q=80"
        : Model.ImageUrl;
}

<section class="page-section">
    <div class="container">
        <div class="detail-layout">
            <div class="surface">
                <div class="detail-hero">
                    <img class="detail-hero__image" src="@imageUrl" alt="@Model.Title" />
                </div>
                <div class="surface__body">
                    <div class="d-flex flex-wrap justify-content-between align-items-start gap-3 mb-3">
                        <div>
                            <h1 class="detail-title">@Model.Title</h1>
                            <div class="detail-meta">@Model.City, @Model.Department</div>
                        </div>
                        <span class="price-badge">@Model.Price.ToString("C") / day</span>
                    </div>

                    <p class="mb-3">@Model.Description</p>

                    <div class="row g-3 mb-3">
                        <div class="col-md-6">
                            <div class="surface__body p-0">
                                <div class="muted">Address</div>
                                <div>@Model.Address</div>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="surface__body p-0">
                                <div class="muted">Owner</div>
                                <div>@Model.OwnerFullName</div>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="surface__body p-0">
                                <div class="muted">Created at</div>
                                <div>@Model.CreatedAt.ToString("yyyy-MM-dd HH:mm")</div>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="surface__body p-0">
                                <div class="muted">Updated at</div>
                                <div>@Model.UpdatedAt?.ToString("yyyy-MM-dd HH:mm")</div>
                            </div>
                        </div>
                    </div>

                    <div class="d-flex flex-wrap gap-2">
                        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary">Edit apartment</a>
                        <form asp-action="Destroy" asp-route-id="@Model.Id" method="post" class="d-inline">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-outline-dark">Delete apartment</button>
                        </form>
                        <a asp-action="Index" class="btn btn-outline-dark">Back</a>
                    </div>
                </div>
            </div>

            <div class="surface">
                <div class="surface__header">
                    <h2 class="section-title">Apartment data</h2>
                    <p class="section-subtitle">Reference values for internal management.</p>
                </div>
                <div class="surface__body">
                    <div class="mb-3">
                        <div class="muted">Identifier</div>
                        <div>@Model.Id</div>
                    </div>
                    <div class="mb-3">
                        <div class="muted">Owner ID</div>
                        <div>@Model.OwnerId</div>
                    </div>
                    <div class="mb-3">
                        <div class="muted">Deleted at</div>
                        <div>@Model.DeletedAt?.ToString("yyyy-MM-dd HH:mm")</div>
                    </div>
                    <div>
                        <div class="muted">Image URL</div>
                        <div class="text-break">@Model.ImageUrl</div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
