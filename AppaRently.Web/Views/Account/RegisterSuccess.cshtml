@model UserResponse
@{
    ViewData["Title"] = "Registration complete";
    var loginUrl = Url.Action("Login", "Account") ?? "/";
}

<section class="auth-page">
    <div class="auth-card">
        <div class="auth-card__body">
            <h1 class="h3 mb-2">Registration complete</h1>
            <p class="muted mb-3">Your account has been created for @Model.Email.</p>
            <p class="mb-4">You will be redirected to the login page shortly.</p>

            <div class="d-flex gap-2">
                <a asp-controller="Account" asp-action="Login" class="btn btn-primary">Go to login</a>
                <a asp-controller="Apartment" asp-action="Index" class="btn btn-outline-dark">Dashboard</a>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    <script>
        setTimeout(function () {
            window.location.href = '@loginUrl';
        }, 3000);
    </script>
}
