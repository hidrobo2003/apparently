@inject IAppNotificationService NotificationService
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - AppaRently Client</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/AppaRently.Web.Client.styles.css" asp-append-version="true" />
</head>
<body>
    <div class="page-shell d-flex flex-column min-vh-100">
        <header class="site-header border-bottom">
            <nav class="navbar navbar-expand-lg navbar-light bg-white">
                <div class="container py-2">
                    @{
                        var unreadNotifications = 0;
                        if (User.Identity?.IsAuthenticated == true)
                        {
                            var userId = User.FindFirstValue(ClaimTypes.NameIdentifier);
                            if (!string.IsNullOrWhiteSpace(userId))
                            {
                                unreadNotifications = await NotificationService.CountUnreadAsync(userId, favoritesOnly: true);
                            }
                        }
                    }
                    <a class="navbar-brand fw-semibold" asp-controller="Home" asp-action="Index">AppaRently</a>
                    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#siteNav" aria-controls="siteNav" aria-expanded="false" aria-label="Toggle navigation">
                        <span class="navbar-toggler-icon"></span>
                    </button>
                    <div class="collapse navbar-collapse" id="siteNav">
                        <div class="ms-auto d-flex flex-column flex-lg-row align-items-lg-center gap-2 pt-3 pt-lg-0">
                            <a class="btn btn-outline-primary btn-sm" asp-controller="Apartment" asp-action="Index">Dashboard</a>
                            <a class="btn btn-outline-secondary btn-sm" href="http://localhost:5002/" target="_blank" rel="noreferrer">Owner Portal</a>

                            @if (User.Identity?.IsAuthenticated == true)
                            {
                                <a class="btn btn-outline-dark btn-sm" asp-controller="User" asp-action="Profile">Profile</a>
                                <a class="btn btn-outline-dark btn-sm" asp-controller="Favorite" asp-action="Index">Favorites</a>
                                <a class="btn btn-outline-dark btn-sm" asp-controller="Reservation" asp-action="Index">Reservations</a>
                                <a class="btn btn-outline-dark btn-sm position-relative" asp-controller="Notification" asp-action="Index">
                                    Notifications
                                    @if (unreadNotifications > 0)
                                    {
                                        <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger">@unreadNotifications</span>
                                    }
                                </a>
                                <form asp-controller="Account" asp-action="Logout" method="post" class="d-inline">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-primary btn-sm">Logout</button>
                                </form>
                            }
                            else
                            {
                                <a class="btn btn-outline-dark btn-sm" asp-controller="Account" asp-action="Login">Login</a>
                                <a class="btn btn-primary btn-sm" asp-controller="Account" asp-action="Register">Register</a>
                            }
                        </div>
                    </div>
                </div>
            </nav>
        </header>

        <main class="flex-grow-1">
            @RenderBody()
        </main>

        <footer class="site-footer border-top py-3 mt-auto">
            <div class="container d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-2">
                <span>AppaRently Client</span>
                <a asp-controller="Home" asp-action="Privacy">Privacy</a>
            </div>
        </footer>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
