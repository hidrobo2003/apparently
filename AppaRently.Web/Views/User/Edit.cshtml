@model EditUserViewModel
@{
    ViewData["Title"] = "Edit profile";
}

<section class="auth-page">
    <div class="auth-card">
        <div class="auth-card__body">
            <h1 class="h3 mb-2">Edit profile</h1>
            <p class="muted mb-4">Update your account details and optionally change your password.</p>

            <form asp-action="Upgrade" asp-route-id="@Model.Id" method="post">
                @Html.AntiForgeryToken()
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <input type="hidden" asp-for="Id" />
                <input type="hidden" asp-for="Email" />
                <input type="hidden" asp-for="Role" />
                <input type="hidden" asp-for="CreatedAt" />
                <input type="hidden" asp-for="UpdatedAt" />
                <input type="hidden" asp-for="DeletedAt" />

                <div class="mb-3">
                    <label asp-for="FullName" class="form-label"></label>
                    <input asp-for="FullName" class="form-control" />
                    <span asp-validation-for="FullName" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label class="form-label">Email</label>
                    <input class="form-control" value="@Model.Email" disabled />
                </div>

                <div class="form-check mb-3">
                    <input asp-for="ChangePassword" class="form-check-input" id="changePassword" />
                    <label asp-for="ChangePassword" class="form-check-label">Change password</label>
                </div>

                <div id="passwordFields" class="d-none">
                    <div class="mb-3">
                        <label asp-for="NewPassword" class="form-label">New password</label>
                        <input asp-for="NewPassword" class="form-control" type="password" autocomplete="new-password" data-password-field="true" />
                        <span asp-validation-for="NewPassword" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="ConfirmNewPassword" class="form-label">Confirm new password</label>
                        <input asp-for="ConfirmNewPassword" class="form-control" type="password" autocomplete="new-password" data-password-field="true" />
                        <span asp-validation-for="ConfirmNewPassword" class="text-danger"></span>
                    </div>
                </div>

                <button type="submit" class="btn btn-primary w-100">Save changes</button>
            </form>
        </div>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        (() => {
            const checkbox = document.getElementById('changePassword');
            const fields = document.getElementById('passwordFields');
            const inputs = fields.querySelectorAll('[data-password-field="true"]');

            const sync = () => {
                const enabled = checkbox.checked;
                fields.classList.toggle('d-none', !enabled);
                inputs.forEach(input => {
                    input.disabled = !enabled;
                    if (!enabled) {
                        input.value = '';
                    }
                });
            };

            checkbox.addEventListener('change', sync);
            sync();
        })();
    </script>
}
