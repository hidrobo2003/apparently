@model ProfileViewModel
@{
    ViewData["Title"] = "Profile";
}

<section class="page-section">
    <div class="container">
        <div class="profile-grid">
            <div class="profile-card">
                <div class="profile-card__body">
                    <h1 class="h3 mb-3">Profile</h1>

                    <div class="mb-3">
                        <div class="muted">Full name</div>
                        <div>@Model.User.FullName</div>
                    </div>

                    <div class="mb-3">
                        <div class="muted">Email</div>
                        <div>@Model.User.Email</div>
                    </div>

                    <div class="mb-3">
                        <div class="muted">Role</div>
                        <div>@Model.User.Role</div>
                    </div>

                    <div class="mb-4">
                        <div class="muted">Account created</div>
                        <div>@Model.User.CreatedAt.ToString("yyyy-MM-dd HH:mm")</div>
                    </div>

                    <div class="d-flex flex-wrap gap-2">
                        <a asp-action="Edit" asp-route-id="@Model.User.Id" class="btn btn-primary">Update information</a>
                        <form asp-action="Destroy" asp-route-id="@Model.User.Id" method="post" class="d-inline">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-outline-dark">Delete account</button>
                        </form>
                    </div>
                </div>
            </div>

            <div class="surface">
                <div class="surface__header">
                    <h2 class="section-title">Reservation history</h2>
                    <p class="section-subtitle">Most recent reservations appear first.</p>
                </div>
                <div class="surface__body">
                    @if (Model.Reservations.Count == 0)
                    {
                        <p class="mb-0 muted">No reservations found.</p>
                    }
                    else
                    {
                        <div class="table-responsive">
                            <table class="table align-middle mb-0">
                                <thead>
                                    <tr>
                                        <th>Apartment</th>
                                        <th>Check-in</th>
                                        <th>Check-out</th>
                                        <th>Created</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var reservation in Model.Reservations)
                                    {
                                        <tr>
                                            <td>
                                                <div class="fw-semibold">@reservation.ApartmentTitle</div>
                                                <div class="muted">@reservation.ApartmentAddress</div>
                                            </td>
                                            <td>@reservation.CheckIn.ToString("yyyy-MM-dd")</td>
                                            <td>@reservation.CheckOut.ToString("yyyy-MM-dd")</td>
                                            <td>@reservation.CreatedAt.ToString("yyyy-MM-dd HH:mm")</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</section>
