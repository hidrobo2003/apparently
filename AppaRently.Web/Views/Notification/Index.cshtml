@model IReadOnlyList<NotificationResponse>
@{
    ViewData["Title"] = "Notifications";
    var unreadOnly = ViewData["UnreadOnly"] as bool? ?? false;
}

<section class="page-section">
    <div class="container">
        <div class="surface mb-4">
            <div class="surface__header surface__header--split">
                <div>
                    <h1 class="section-title">Notifications</h1>
                    <p class="section-subtitle mb-0">Recent updates from the platform appear here.</p>
                </div>
                <div class="toolbar">
                    <a asp-action="Index" asp-route-unreadOnly="true" class="btn btn-outline-dark @(unreadOnly ? "active" : string.Empty)">Unread</a>
                    <a asp-action="Index" class="btn btn-outline-dark @(!unreadOnly ? "active" : string.Empty)">All</a>
                    <form asp-action="ReadAll" asp-route-unreadOnly="@unreadOnly" method="post" class="d-inline">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-primary">Mark all read</button>
                    </form>
                </div>
            </div>
        </div>

        @if (!Model.Any())
        {
            <div class="surface">
                <div class="surface__body">
                    <p class="mb-0 muted">No notifications found.</p>
                </div>
            </div>
        }
        else
        {
            <div class="stack gap-3">
                @foreach (var notification in Model)
                {
                    <article class="surface">
                        <div class="surface__body">
                            <div class="d-flex justify-content-between align-items-start gap-3">
                                <div>
                                    <div class="d-flex align-items-center gap-2 mb-1">
                                        <h2 class="h5 mb-0">@notification.Title</h2>
                                        @if (!notification.IsRead)
                                        {
                                            <span class="badge bg-danger">New</span>
                                        }
                                    </div>
                                    <div class="text-muted">@notification.Type</div>
                                </div>
                                <div class="text-muted">@notification.CreatedAt.ToString("yyyy-MM-dd HH:mm")</div>
                            </div>

                            <p class="mt-3 mb-3">@notification.Body</p>

                            <div class="d-flex flex-wrap gap-2">
                                @if (!string.IsNullOrWhiteSpace(notification.ActionUrl))
                                {
                                    <a href="@notification.ActionUrl" class="btn btn-outline-dark btn-sm">Open</a>
                                }
                                @if (!notification.IsRead)
                                {
                                    <form asp-action="Read" asp-route-id="@notification.Id" asp-route-unreadOnly="@unreadOnly" method="post" class="d-inline">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-primary btn-sm">Mark read</button>
                                    </form>
                                }
                            </div>
                        </div>
                    </article>
                }
            </div>
        }
    </div>
</section>
