@model CreateFavoriteRequest
@{
    ViewData["Title"] = "Add to favorites";
}

<section class="auth-page">
    <div class="auth-card">
        <div class="auth-card__body">
            <h1 class="h3 mb-2">Add to favorites</h1>
            <p class="muted mb-4">Confirm that you want to save this apartment.</p>

            <form asp-action="Storage" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="ApartmentId" />

                <button type="submit" class="btn btn-primary w-100">Save apartment</button>
            </form>

            <div class="mt-3 text-center">
                <a asp-controller="Apartment" asp-action="Detail" asp-route-id="@Model.ApartmentId">Cancel</a>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
