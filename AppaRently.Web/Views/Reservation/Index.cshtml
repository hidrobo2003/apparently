@model IEnumerable<ReservationResponse>
@{
    ViewData["Title"] = "Reservations";
}

<section class="page-section">
    <div class="container">
        <div class="surface mb-4">
            <div class="surface__header">
                <h1 class="section-title">Reservations</h1>
                <p class="section-subtitle">A record of your confirmed bookings.</p>
            </div>
        </div>

        @{
            var reservations = Model.ToList();
        }

        @if (reservations.Count == 0)
        {
            <div class="surface">
                <div class="surface__body">
                    <p class="mb-0 muted">No reservations found.</p>
                </div>
            </div>
        }
        else
        {
            <div class="surface">
                <div class="surface__body">
                    <div class="table-responsive">
                        <table class="table align-middle mb-0">
                            <thead>
                                <tr>
                                    <th>Apartment</th>
                                    <th>Check-in</th>
                                    <th>Check-out</th>
                                    <th>Created</th>
                                    <th></th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var reservation in reservations)
                                {
                                    <tr>
                                        <td>
                                            <div class="fw-semibold">@reservation.ApartmentTitle</div>
                                            <div class="muted">@reservation.ApartmentAddress</div>
                                        </td>
                                        <td>@reservation.CheckIn.ToString("yyyy-MM-dd")</td>
                                        <td>@reservation.CheckOut.ToString("yyyy-MM-dd")</td>
                                        <td>@reservation.CreatedAt.ToString("yyyy-MM-dd HH:mm")</td>
                                        <td class="text-end">
                                            <div class="d-flex justify-content-end gap-2">
                                                <a asp-controller="Apartment" asp-action="Detail" asp-route-id="@reservation.ApartmentId" class="btn btn-outline-dark btn-sm">View apartment</a>
                                                <a asp-action="Show" asp-route-id="@reservation.Id" class="btn btn-primary btn-sm">Open</a>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        }
    </div>
</section>
