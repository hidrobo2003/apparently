@model EditUserViewModel

@{
    ViewData["Title"] = "Update profile";
}

<section class="auth-shell">
    <div class="auth-card">
        <div class="stack">
            <div>
                <span class="eyebrow">Profile</span>
                <h1 class="section-title">Update information</h1>
                <p class="section-subtitle">Keep your profile current and optionally change your password.</p>
            </div>

            <form asp-action="Upgrade" asp-route-id="@Model.Id" method="post" class="stack">
                @Html.AntiForgeryToken()
                <div asp-validation-summary="ModelOnly" class="note"></div>

                <input type="hidden" asp-for="Id" />
                <input type="hidden" asp-for="Email" />
                <input type="hidden" asp-for="Role" />
                <input type="hidden" asp-for="CreatedAt" />
                <input type="hidden" asp-for="UpdatedAt" />
                <input type="hidden" asp-for="DeletedAt" />

                <div class="field">
                    <label class="label" asp-for="FullName"></label>
                    <input class="input" asp-for="FullName" />
                    <span asp-validation-for="FullName" class="note"></span>
                </div>

                <div class="field">
                    <label class="label">Email</label>
                    <input class="input" value="@Model.Email" disabled />
                </div>

                <div class="field">
                    <label class="label" asp-for="ChangePassword"></label>
                    <input asp-for="ChangePassword" type="checkbox" class="form-check-input ms-0" id="changePassword" />
                </div>

                <div id="passwordFields" class="stack d-none">
                    <div class="field">
                        <label class="label" asp-for="NewPassword">New password</label>
                        <input class="input" asp-for="NewPassword" type="password" autocomplete="new-password" data-password-field="true" />
                        <span asp-validation-for="NewPassword" class="note"></span>
                    </div>

                    <div class="field">
                        <label class="label" asp-for="ConfirmNewPassword">Confirm new password</label>
                        <input class="input" asp-for="ConfirmNewPassword" type="password" autocomplete="new-password" data-password-field="true" />
                        <span asp-validation-for="ConfirmNewPassword" class="note"></span>
                    </div>
                </div>

                <button type="submit" class="btn btn-primary">Save changes</button>
                <a asp-action="Profile" class="btn btn-outline">Cancel</a>
            </form>
        </div>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        (() => {
            const checkbox = document.getElementById('changePassword');
            const fields = document.getElementById('passwordFields');
            const inputs = fields.querySelectorAll('[data-password-field="true"]');

            const sync = () => {
                const enabled = checkbox.checked;
                fields.classList.toggle('d-none', !enabled);
                inputs.forEach(input => {
                    input.disabled = !enabled;
                    if (!enabled) {
                        input.value = '';
                    }
                });
            };

            checkbox.addEventListener('change', sync);
            sync();
        })();
    </script>
}
